APP_NAME=LMS Backend
APP_ENV=development
API_V1_PREFIX=/api/v1
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/lms
JWT_SECRET_KEY=change-me-access-secret-key-32-bytes
ACCESS_TOKEN_EXPIRE_MINUTES=60
FRONTEND_ORIGIN=http://localhost:5173
FRONTEND_ORIGIN_ALT=http://127.0.0.1:5173
BACKEND_PUBLIC_URL=http://127.0.0.1:8000
MEDIA_BACKEND=local
LOCAL_MEDIA_PATH=media
LOCAL_MEDIA_URL_PREFIX=/media
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
LLM_PROVIDER=groq
LLM_FALLBACK_PROVIDERS=
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TRANSCRIPTION_MODEL=whisper-large-v3
GROQ_BASE_URL=https://api.groq.com/openai/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1
